#!/usr/bin/env bash
# Context King — platform wrapper.
# Selects the correct pre-built binary for the current OS and architecture.
DIR="$(cd "$(dirname "$0")" && pwd)"
OS="$(uname -s)"
ARCH="$(uname -m)"

if [ "$OS" = "Darwin" ] && [ "$ARCH" = "arm64" ]; then
  exec "$DIR/ck-osx-arm64" "$@"
elif [ "$OS" = "Darwin" ]; then
  exec "$DIR/ck-osx-x64" "$@"
elif echo "$OS" | grep -qiE "^(MINGW|MSYS|CYGWIN)"; then
  exec "$DIR/ck-win-x64.exe" "$@"
else
  exec "$DIR/ck-linux-x64" "$@"
fi
